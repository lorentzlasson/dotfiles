{
  "env": {
    "DISABLE_AUTOUPDATER": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(busy_ports:*)",
      "Bash(echo:*)",
      "Bash(gcloud logging read:*)",
      "Bash(gh pr view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run watch:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(nslookup:*)",
      "Bash(rg:*)",
      "Bash(ssh:*)",
      "Read(//home/lorentz/.claude/**)",
      "Read(//home/lorentz/dev/**)",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Bash(cd:*)",
      "Bash(git checkout:*)",
      "Bash(git -C:*)"
    ],
    "ask": [],
    "defaultMode": "auto"
  },
  "enabledMcpjsonServers": [
    "playwright"
  ],
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true
  },
  "effortLevel": "medium",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "autoMemoryEnabled": false,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
